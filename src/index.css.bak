@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 216 52% 7%;
    --foreground: 220 30% 93%;
    --card: 210 45% 10%;
    --card-foreground: 220 30% 93%;
    --popover: 210 45% 10%;
    --popover-foreground: 220 30% 93%;
    --primary: 174 55% 55%;
    --primary-foreground: 216 52% 7%;
    --secondary: 210 30% 15%;
    --secondary-foreground: 220 30% 93%;
    --muted: 210 20% 20%;
    --muted-foreground: 216 12% 59%;
    --accent: 174 55% 55%;
    --accent-foreground: 216 52% 7%;
    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 0 0% 98%;
    --border: 210 20% 18%;
    --input: 210 20% 18%;
    --ring: 174 55% 55%;
    --radius: 0.25rem;
    --font-heading: 'Outfit', sans-serif;
    --font-body: 'Source Serif 4', serif;
    --font-mono: 'IBM Plex Mono', monospace;
  }

  * {
    @apply border-border;
  }

  html {
    overflow-x: hidden;
    scroll-behavior: auto;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/Edge */
  }

  html::-webkit-scrollbar {
    display: none; /* Chrome/Safari/Opera */
  }

  body {
    @apply bg-[#0B1628] text-[#E8EDF5];
    font-family: var(--font-body);
    overflow-x: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body::-webkit-scrollbar {
    display: none;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
  }
}

@layer components {
  .font-heading {
    font-family: var(--font-heading);
  }

  .font-body {
    font-family: var(--font-body);
  }

  .font-mono {
    font-family: var(--font-mono);
  }

  .text-primary-light {
    color: #E8EDF5;
  }

  .text-secondary-muted {
    color: #8B95A5;
  }

  .text-accent-teal {
    color: #4ECDC4;
  }

  .bg-deep {
    background-color: #0B1628;
  }

  .bg-surface {
    background-color: rgba(11, 22, 40, 0.6);
  }

  .bg-dark-surface {
    background-color: #0D1B2A;
  }

  .bg-footer {
    background-color: #070F1A;
  }

  .border-subtle {
    border-color: rgba(232, 237, 245, 0.06);
  }

  .border-teal-subtle {
    border-color: rgba(78, 205, 196, 0.1);
  }

  .glass-panel {
    background: rgba(13, 27, 42, 0.65);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(78, 205, 196, 0.1);
  }

  @supports not (backdrop-filter: blur(1px)) {
    .glass-panel {
      background: rgba(13, 27, 42, 0.88);
    }
  }

  .label-mono {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #4ECDC4;
  }

  .nav-link {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8B95A5;
    transition: color 0.3s ease;
  }

  .nav-link:hover {
    color: #4ECDC4;
  }

  .reveal-text .line {
    display: block;
    will-change: clip-path;
    transition: clip-path 0.1s linear;
  }
}

@layer utilities {
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }

  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
}
